# Copy to .env and fill the values
# Database (Neon/Supabase/Railway Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="replace-with-strong-random"
NEXTAUTH_URL="http://localhost:3001"

# Supabase (mobile auth)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only service role key (do NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=""

# Fondy (Ukraine payments)
FONDY_MERCHANT_ID=""
FONDY_SECRET=""

# LiveKit (video rooms)
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL="wss://your-livekit-host"

# Resend (emails)
RESEND_API_KEY=""

# Application URLs
SITE_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
PUBLIC_BASE_URL="http://localhost:3001"

# Deep links (Expo)
APP_DEEP_LINK_SCHEME="repetyto"

# Storage (S3/R2 compatible) for media uploads
# For Cloudflare R2, endpoint looks like: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT="https://s3.localhost" 
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="repetitir-dev"
# Public base URL for serving media (e.g., via CDN or S3 website)
NEXT_PUBLIC_STORAGE_PUBLIC_URL="https://cdn.localhost/repetitir-dev"

# Payments sandbox
NEXT_PUBLIC_ENABLE_PAYMENT_SANDBOX="true"

# Currency conversion
USD_UAH_RATE="40"

# Feature flags (dev)
NEXT_PUBLIC_ENABLE_FAVORITES="true"
NEXT_PUBLIC_ENABLE_INFINITE_SCROLL="true"
